<%- include("components/header.ejs") %>

<div class="container py-5">

  <!-- HERO -->
  <section class="text-center py-5">
    <h1 class="fw-bold" style="color: #0078AA;">
      AI Resume Analyzer
    </h1>
    <p class="text-muted mt-3 fs-5">
      Analyze your resume & update your skills 🚀
    </p>
    <a href="/upload">
      <button class="btn mt-3 px-4 py-2 text-white" 
              style="background-color: #0078AA;">
        Analyze Now
      </button>
    </a>
    
  </section>

  <!-- FEATURES -->
  <section class="text-center mt-5">
    <h2 class="fw-bold mb-4" style="color: #0078AA;">Features</h2>

    <div class="row justify-content-center g-4">

      <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5>📄 Resume Analysis</h5>
            <p class="text-muted">Upload and analyze your resume instantly</p>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5>📊 ATS Score</h5>
            <p class="text-muted">Check your resume compatibility</p>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5>🤖 AI Suggestions</h5>
            <p class="text-muted">Improve your resume with smart tips</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- STEPS -->
  <section class="text-center mt-5">
    <h2 class="fw-bold mb-4" style="color: #0078AA;">How It Works</h2>

    <div class="row justify-content-center g-4">

      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <span class="badge rounded-pill mb-2" style="background:#3AB4F2;">1</span>
            <h5>Upload Resume</h5>
            <p class="text-muted">Select your PDF</p>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <span class="badge rounded-pill mb-2" style="background:#3AB4F2;">2</span>
            <h5>Analyze</h5>
            <p class="text-muted">AI scans your resume</p>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <span class="badge rounded-pill mb-2" style="background:#3AB4F2;">3</span>
            <h5>Get Results</h5>
            <p class="text-muted">View score & suggestions</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- STATS -->
  <section class="text-center mt-5">
    <h2 class="fw-bold mb-4" style="color: #0078AA;">Our Impact</h2>

    <div class="row justify-content-center g-4">

      <div class="col-md-2">
        <div class="p-3 bg-white shadow-sm rounded">
          <h4 style="color:#0078AA;">1000+</h4>
          <p class="text-muted mb-0">Resumes</p>
        </div>
      </div>

      <div class="col-md-2">
        <div class="p-3 bg-white shadow-sm rounded">
          <h4 style="color:#0078AA;">500+</h4>
          <p class="text-muted mb-0">Users</p>
        </div>
      </div>

      <div class="col-md-2">
        <div class="p-3 bg-white shadow-sm rounded">
          <h4 style="color:#0078AA;">90%</h4>
          <p class="text-muted mb-0">Accuracy</p>
        </div>
      </div>

    </div>
  </section>

</div>

<%- include("components/footer.ejs") %>