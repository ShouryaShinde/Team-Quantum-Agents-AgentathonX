<body class="bg-light">

<div class="container mt-5">

  <h2 class="text-center mb-4">AI Resume Dashboard</h2>

  <!-- SCORE -->
  <div class="card p-4 mb-4 text-center shadow">
    <h4>Resume Score</h4>
    <h1 class="display-4">7/10</h1>

    <div class="progress mt-3">
      <div 
        class="progress-bar bg-success"
        role="progressbar"
        data-score="7"
        aria-valuenow="7"
        aria-valuemin="0"
        aria-valuemax="10">
      </div>
    </div>
  </div>

  <div class="row">

    <!-- BAR CHART -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>Statistics</h5>
        <canvas id="barChart"></canvas>
      </div>
    </div>

    <!-- PIE CHART -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>Score Breakdown</h5>
        <canvas id="pieChart"></canvas>
      </div>
    </div>

  </div>

  <div class="row">

    <!-- SKILLS -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>Skills Found</h5>
        <span class="badge bg-primary m-1 p-2">Python</span>
        <span class="badge bg-primary m-1 p-2">Machine Learning</span>
        <span class="badge bg-primary m-1 p-2">SQL</span>
        <span class="badge bg-primary m-1 p-2">FastAPI</span>
        <span class="badge bg-primary m-1 p-2">Data Analysis</span>
      </div>
    </div>

    <!-- SUGGESTIONS -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>AI Suggestions</h5>
        <ul>
          <li>Add Docker experience to your resume</li>
          <li>Include cloud skills like AWS or GCP</li>
          <li>Add more project descriptions</li>
          <li>Mention team collaboration experience</li>
        </ul>
      </div>
    </div>

  </div>

</div>

<script>
  // PROGRESS BAR WIDTH
  document.querySelectorAll('.progress-bar[data-score]').forEach(bar => {
    const score = bar.getAttribute('data-score');
    bar.style.width = (score * 10) + '%';
  });

  // BAR CHART
  const barCtx = document.getElementById('barChart').getContext('2d');
  new Chart(barCtx, {
    type: 'bar',
    data: {
      labels: ['Skills', 'Projects', 'Experience', 'Education', 'Certifications'],
      datasets: [{
        label: 'Analysis',
        data: [8, 6, 7, 9, 5],
        backgroundColor: 'rgba(54, 162, 235, 0.7)',
        borderColor: 'rgba(54, 162, 235, 1)',
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      scales: { y: { beginAtZero: true } }
    }
  });

  // PIE CHART
  const pieCtx = document.getElementById('pieChart').getContext('2d');
  new Chart(pieCtx, {
    type: 'pie',
    data: {
      labels: ["Skills", "Projects", "Experience"],
      datasets: [{
        data: [40, 35, 25],
        backgroundColor: [
          'rgba(75, 192, 192, 0.7)',
          'rgba(255, 205, 86, 0.7)',
          'rgba(255, 99, 132, 0.7)'
        ]
      }]
    },
    options: { responsive: true }
  });
</script>

</body>