<%- include("components/header.ejs") %>
<div class="container py-5" style="max-width: 960px;">

  <!-- Welcome -->
  <div class="mb-4">
    <h1>Report Analysis</h1>
    <h2  style="color:#0078AA; font-weight : 300 ;">
      <%= result.welcomeMessage %>
    </h2>
  </div>

  <!-- Score + Categories -->
  <div class="row g-4 mb-4">

    <!-- Overall Score -->
    <div class="col-lg-4">
      <div class="card card-custom p-4 text-center h-100">
        <p class="text-uppercase small fw-medium text-muted mb-3">Overall Score</p>

        <div class="position-relative mx-auto score-ring mb-3">
          <svg viewBox="0 0 120 120" class="w-100 h-100" style="transform: rotate(-90deg);">
            <circle cx="60" cy="60" r="52" fill="none" stroke="#e9ecef" stroke-width="10" />
            <circle id="scoreCircle"
            cx="60" cy="60" r="52"
            fill="none"
            stroke="red"
            stroke-width="10"
            stroke-linecap="round"
            stroke-dasharray="0 327" />
          </svg>

          <div class="position-absolute top-50 start-50 translate-middle">
            <span id="scoreValue" class="fs-1 fw-bold">0</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Category Breakdown -->
    <div class="col-lg-8">
      <div class="card card-custom p-4 h-100">
        <h2 class="fs-5 fw-semibold mb-4">Category Breakdown</h2>

        <!-- ATS -->
        <div class="mb-3">
          <div class="d-flex justify-content-between small mb-1">
            <span>ATS Compatibility</span>
            <span><%= result.atsScore %>%</span>
          </div>
          <div class="progress bg-light">
            <div class="progress-bar" style="width: <%= result.atsScore %>%; background:#0078AA;"></div>
          </div>
        </div>

        <!-- Keyword -->
        <div class="mb-3">
          <div class="d-flex justify-content-between small mb-1">
            <span>Keyword Optimization</span>
            <span><%= result.keywordOptimization %>%</span>
          </div>
          <div class="progress bg-light">
            <div class="progress-bar" style="width: <%= result.keywordOptimization %>%; background:#3AB4F2;"></div>
          </div>
        </div>

        <!-- Formatting -->
        <div class="mb-3">
          <div class="d-flex justify-content-between small mb-1">
            <span>Formatting & Structure</span>
            <span><%= result.formattingandStructure %>%</span>
          </div>
          <div class="progress bg-light">
            <div class="progress-bar" style="width: <%= result.formattingandStructure %>%; background:#0078AA;"></div>
          </div>
        </div>

        <!-- Impact -->
        <div>
          <div class="d-flex justify-content-between small mb-1">
            <span>Impact Statements</span>
            <span><%= result.impactStatements %>%</span>
          </div>
          <div class="progress bg-light">
            <div class="progress-bar" style="width: <%= result.impactStatements %>%; background:#3AB4F2;"></div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Strengths + Weakness -->
  <div class="row g-4 mb-4">

    <!-- Strengths -->
    <div class="col-lg-6">
      <div class="card card-custom p-4 h-100">
        <h2 class="fs-5 fw-semibold mb-3 text-success">Strengths</h2>

        <ul class="list-unstyled">
          <% result.strongPoints.forEach(point => { %>
            <li class="mb-2">
              <i class="bi bi-check text-success"></i> <%= point %>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>

    <!-- Weakness -->
    <div class="col-lg-6">
      <div class="card card-custom p-4 h-100">
        <h2 class="fs-5 fw-semibold mb-3 text-danger">Weak Points</h2>

        <ul class="list-unstyled">
          <% result.weakPoints.forEach(point => { %>
            <li class="mb-2">
              <i class="bi bi-exclamation-triangle text-warning"></i> <%= point %>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>

  </div>

  <!-- Suggestions -->
  <div class="card card-custom p-4">
    <h2 class="fs-5 fw-semibold mb-3"><i class="bi bi-stars text-primary"></i>AI Suggestions</h2>

    <ul class="list-unstyled">
      <% result.suggestions.forEach(s => { %>
        <li class="mb-2"><i class="bi bi-dot"></i> <%= s %></li>
      <% }) %>
    </ul>
  </div>

</div>

<script>
  const score = <%= result.overallScore %>;
  const circle = document.getElementById("scoreCircle");
  const text = document.getElementById("scoreValue");
  const radius = 52;
  const circumference = 2 * Math.PI * radius;
  let current = 0;
  function getColor(value) {
    if (value < 50) return "red";
    if (value < 75) return "#eab308"; 
    return "green";
  }
  const interval = setInterval(() => {
    if (current >= score) {
      clearInterval(interval);
      return;
    }
    current++;
    text.innerText = current;
    const progress = (current / 100) * circumference;
    circle.style.strokeDasharray = `${progress} ${circumference}`;
    const color = getColor(current);
    circle.style.stroke = color;
    text.style.color = color;
  }, 15);
</script>

<%- include("components/footer.ejs") %>