<body class="bg-light">

<div class="container mt-5">

  <h2 class="text-center mb-4">AI Resume Dashboard</h2>

  <!-- SCORE -->
  <div class="card p-4 mb-4 text-center shadow">
    <h4>Resume Score</h4>

    <% let score = (data && data.score) ? data.score : 0; %>
    <h1 class="display-4"><%= score %>/10</h1>

    <% let color = score >= 7 ? 'bg-success' : (score >= 5 ? 'bg-warning' : 'bg-danger'); %>

    <!-- FIX 1: removed inline EJS style, added data-score + data-color -->
    <div class="progress mt-3">
      <div 
        class="progress-bar <%= color %>"
        role="progressbar"
        data-score="<%= score %>"
        aria-valuenow="<%= score %>"
        aria-valuemin="0"
        aria-valuemax="10">
      </div>
    </div>
  </div>

  <div class="row">

    <!-- BAR CHART -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>Statistics</h5>
        <canvas id="barChart"></canvas>
      </div>
    </div>

    <!-- PIE CHART -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>Score Breakdown</h5>
        <canvas id="pieChart"></canvas>
      </div>
    </div>

  </div>

  <div class="row">

    <!-- SKILLS -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>Skills Found</h5>
        <% let skills = (data && data.skills) ? data.skills : []; %>
        <% skills.forEach(function(skill){ %>
          <span class="badge bg-primary m-1 p-2"><%= skill %></span>
        <% }) %>
      </div>
    </div>

    <!-- SUGGESTIONS -->
    <div class="col-md-6">
      <div class="card p-4 mb-4 shadow">
        <h5>AI Suggestions</h5>
        <% let suggestions = (data && data.suggestions) ? data.suggestions : []; %>
        <ul>
          <% suggestions.forEach(function(s){ %>
            <li><%= s %></li>
          <% }) %>
        </ul>
      </div>
    </div>

  </div>

</div>

<!-- SAFE DATA TRANSFER -->
<script id="chartData" type="application/json">
  <%- JSON.stringify({
    chartData: data && data.chartData ? data.chartData : { labels: [], values: [] },
    scoreBreakdown: data && data.scoreBreakdown ? data.scoreBreakdown : { skills: 0, projects: 0, experience: 0 }
  }) %>
</script>

<script>
  // FIX 2: Set progress bar width via JS (fixes EJS inline style error)
  document.querySelectorAll('.progress-bar[data-score]').forEach(bar => {
    const score = bar.getAttribute('data-score');
    bar.style.width = (score * 10) + '%';
  });

  // READ JSON SAFELY
  const rawData = JSON.parse(document.getElementById('chartData').textContent);

  const chartLabels = rawData.chartData.labels;
  const chartValues = rawData.chartData.values;
  const breakdown = rawData.scoreBreakdown;

  // FIX 3: Bar Chart — added backgroundColor
  const barCtx = document.getElementById('barChart').getContext('2d');
  new Chart(barCtx, {
    type: 'bar',
    data: {
      labels: chartLabels,
      datasets: [{
        label: 'Analysis',
        data: chartValues,
        backgroundColor: 'rgba(54, 162, 235, 0.7)',
        borderColor: 'rgba(54, 162, 235, 1)',
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      scales: { y: { beginAtZero: true } }
    }
  });

  // FIX 4: Pie Chart — added backgroundColor
  const pieCtx = document.getElementById('pieChart').getContext('2d');
  new Chart(pieCtx, {
    type: 'pie',
    data: {
      labels: ["Skills", "Projects", "Experience"],
      datasets: [{
        data: [
          breakdown.skills,
          breakdown.projects,
          breakdown.experience
        ],
        backgroundColor: [
          'rgba(75, 192, 192, 0.7)',
          'rgba(255, 205, 86, 0.7)',
          'rgba(255, 99, 132, 0.7)'
        ]
      }]
    },
    options: { responsive: true }
  });
</script>

</body>
</html>